# Enable the built-in certificate bundle so HTTPS webhooks can be verified.
CONFIG_MBEDTLS_CERTIFICATE_BUNDLE=y
CONFIG_MBEDTLS_CERTIFICATE_BUNDLE_DEFAULT_FULL=y

# Match the detected flash size on the connected ESP32-S3 board.
CONFIG_ESPTOOLPY_FLASHSIZE_16MB=y
CONFIG_ESPTOOLPY_FLASHSIZE="16MB"
CONFIG_PARTITION_TABLE_CUSTOM=y
CONFIG_PARTITION_TABLE_CUSTOM_FILENAME="partitions.csv"
CONFIG_BOOTLOADER_APP_ROLLBACK_ENABLE=y

# Enable the fallback setup hotspot so the device stays reachable after Wi-Fi failures.
CONFIG_RPC_WIFI_FALLBACK_AP_ENABLE=y
CONFIG_RPC_WIFI_FALLBACK_AP_SSID="esp32-power-controller-setup"
CONFIG_RPC_WIFI_FALLBACK_AP_PASSWORD="esp32setup"
CONFIG_RPC_WIFI_FALLBACK_AP_CHANNEL=1

# Keep the task watchdog enabled for self-recovery.
CONFIG_ESP_TASK_WDT_EN=y
CONFIG_ESP_TASK_WDT_INIT=y
CONFIG_ESP_TASK_WDT_TIMEOUT_S=10
CONFIG_ESP_TASK_WDT_PANIC=y

# Use GPIO14 for the SG90 servo control signal on this hardware build.
CONFIG_RPC_SERVO_GPIO=14
CONFIG_RPC_SERVO_REST_ANGLE=0
CONFIG_RPC_SERVO_PRESS_ANGLE=65
CONFIG_RPC_SERVO_READY_ANGLE=0
CONFIG_RPC_SERVO_SHORT_PRESS_ANGLE=65
CONFIG_RPC_SERVO_LONG_PRESS_ANGLE=65
CONFIG_RPC_SHORT_PRESS_MS=250
CONFIG_RPC_LONG_PRESS_MS=6000
CONFIG_RPC_SERVO_PREPARE_SETTLE_MS=150
CONFIG_RPC_SERVO_RELEASE_SETTLE_MS=150
